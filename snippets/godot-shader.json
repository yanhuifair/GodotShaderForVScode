	"Complete Canvas Item Shader": {
		"prefix": "shader-canvas-full",
		"body": [
			"shader_type canvas_item;",
			"",
			"// ============================================================================",
			"// Uniforms",
			"// ============================================================================",
			"uniform vec4 modulate_color : source_color = vec4(1.0);",
			"uniform float time_scale : hint_range(0.0, 5.0) = 1.0;",
			"uniform sampler2D noise_texture : hint_default_white;",
			"",
			"// ============================================================================",
			"// Vertex Function",
			"// ============================================================================",
			"void vertex() {",
			"\t// Vertex shader code here",
			"\t$0",
			"}",
			"",
			"// ============================================================================",
			"// Fragment Function",
			"// ============================================================================",
			"void fragment() {",
			"\t// Sample texture",
			"\tvec4 tex_color = texture(TEXTURE, UV);",
			"\t",
			"\t// Apply modulation",
			"\tCOLOR = tex_color * modulate_color;",
			"}"
		],
		"description": "Complete CanvasItem shader with comments"
	},
	"Complete Spatial Shader": {
		"prefix": "shader-spatial-full",
		"body": [
			"shader_type spatial;",
			"render_mode cull_back, diffuse_lambert, specular_schlick_ggx;",
			"",
			"// ============================================================================",
			"// Uniforms",
			"// ============================================================================",
			"uniform vec4 albedo : source_color = vec4(1.0);",
			"uniform sampler2D albedo_texture : hint_default_white;",
			"uniform float metallic : hint_range(0.0, 1.0) = 0.0;",
			"uniform float roughness : hint_range(0.0, 1.0) = 1.0;",
			"uniform vec3 emission : source_color = vec3(0.0);",
			"",
			"// ============================================================================",
			"// Vertex Function",
			"// ============================================================================",
			"void vertex() {",
			"\t// Animate vertex position",
			"\t${1:VERTEX.y += sin(TIME * 2.0 + VERTEX.x) * 0.1;}",
			"\t$0",
			"}",
			"",
			"// ============================================================================",
			"// Fragment Function",
			"// ============================================================================",
			"void fragment() {",
			"\t// Sample albedo texture",
			"\tvec3 albedo_tex = texture(albedo_texture, UV).rgb;",
			"\t",
			"\t// Set material properties",
			"\tALBEDO = albedo.rgb * albedo_tex;",
			"\tMETALLIC = metallic;",
			"\tROUGHNESS = roughness;",
			"\tEMISSION = emission;",
			"}",
			"",
			"// ============================================================================",
			"// Light Function",
			"// ============================================================================",
			"void light() {",
			"\t// Custom lighting calculation",
			"\tDIFFUSE_LIGHT = vec3(1.0);",
			"\tSPECULAR_LIGHT = vec3(1.0);",
			"}"
		],
		"description": "Complete Spatial shader with vertex, fragment, and light functions"
	},
