{
	"Canvas Item Shader": {
		"prefix": "shader-canvas",
		"body": [
			"shader_type canvas_item;",
			"",
			"// Uniforms",
			"uniform vec4 modulate_color : source_color = vec4(1.0);",
			"uniform float amount : hint_range(0.0, 1.0) = 0.5;",
			"",
			"void fragment() {",
			"\t$0",
			"\tCOLOR = texture(TEXTURE, UV);",
			"}"
		],
		"description": "Basic CanvasItem shader template"
	},
	"Spatial Shader": {
		"prefix": "shader-spatial",
		"body": [
			"shader_type spatial;",
			"render_mode cull_back, diffuse_lambert, specular_schlick_ggx;",
			"",
			"// Uniforms",
			"uniform vec4 albedo : source_color = vec4(1.0);",
			"uniform sampler2D texture_map : hint_default_white;",
			"uniform float metallic : hint_range(0.0, 1.0) = 0.0;",
			"uniform float roughness : hint_range(0.0, 1.0) = 1.0;",
			"",
			"void vertex() {",
			"\t$0",
			"}",
			"",
			"void fragment() {",
			"\tALBEDO = albedo.rgb;",
			"\tMETALLIC = metallic;",
			"\tROUGHNESS = roughness;",
			"}"
		],
		"description": "Basic Spatial shader template"
	},
	"Sky Shader": {
		"prefix": "shader-sky",
		"body": [
			"shader_type sky;",
			"render_mode use_half_res_pass;",
			"",
			"// Uniforms",
			"uniform vec4 sky_color : source_color = vec4(0.4, 0.6, 1.0, 1.0);",
			"uniform float energy : hint_range(0.0, 2.0) = 1.0;",
			"",
			"void sky() {",
			"\t$0",
			"\tCOLOR = sky_color.rgb;",
			"\tALPHA = sky_color.a;",
			"}"
		],
		"description": "Sky shader template"
	},
