{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GodotShader",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#preprocessor"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtin-constants"
    },
    {
      "include": "#builtin-variables-vertex"
    },
    {
      "include": "#builtin-variables-fragment"
    },
    {
      "include": "#builtin-variables-canvasitem"
    },
    {
      "include": "#builtin-variables-particles"
    },
    {
      "include": "#builtin-variables-light"
    },
    {
      "include": "#builtin-matrices-vertex"
    },
    {
      "include": "#builtin-matrices-fragment"
    },
    {
      "include": "#builtin-matrices-light"
    },
    {
      "include": "#builtin-variables-sky"
    },
    {
      "include": "#builtin-variables-fog"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#hint-attributes"
    },
    {
      "include": "#render-mode-values"
    },
    {
      "include": "#stencil-mode-values"
    },
    {
      "include": "#shader-type-values"
    },
    {
      "include": "#swizzle"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#punctuation-comma"
    },
    {
      "include": "#punctuation-semicolon"
    },
    {
      "include": "#punctuation-dot"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gdshader",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.gdshader"
            }
          }
        },
        {
          "name": "comment.block.gdshader",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.gdshader"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.gdshader"
            }
          }
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.gdshader",
          "match": "#\\s*(if|ifdef|ifndef|else|elif|endif|define|undef|include|warning|error|pragma)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gdshader",
          "match": "\\b(shader_type|render_mode|stencil_mode|void|return|if|else|for|while|do|break|continue|switch|case|default|discard|true|false)\\b"
        },
        {
          "name": "keyword.other.gdshader",
          "match": "\\b(in|out|inout|uniform|varying|const|struct)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.gdshader",
          "match": "\\b(vec2|vec3|vec4|ivec2|ivec3|ivec4|uvec2|uvec3|uvec4|bvec2|bvec3|bvec4|float|int|uint|bool|mat2|mat3|mat4|sampler2D|samplerCube|sampler2DArray|samplerExternalOES)\\b"
        }
      ]
    },
    "builtin-constants": {
      "patterns": [
        {
          "name": "constant.language.gdshader",
          "match": "\\b(TIME|PI|TAU|E|OUTPUT_IS_SRGB|CLIP_SPACE_FAR|VIEWPORT_SIZE|CURRENT_RENDERER|RENDERER_FORWARD_PLUS|RENDERER_MOBILE|RENDERER_COMPATIBILITY|RENDERER_FORWARD|IS_MULTIVIEW|IN_SHADOW_PASS)\\b"
        }
      ]
    },
    "builtin-variables-vertex": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(VERTEX|NORMAL|TANGENT|BINORMAL|UV|UV2|COLOR|POINT_SIZE|POSITION|ROUGHNESS|VIEWPORT_SIZE|VIEW_MATRIX|INV_VIEW_MATRIX|INV_PROJECTION_MATRIX|NODE_POSITION_WORLD|NODE_POSITION_VIEW|CAMERA_POSITION_WORLD|CAMERA_DIRECTION_WORLD|CAMERA_VISIBLE_LAYERS|INSTANCE_ID|INSTANCE_CUSTOM|VIEW_INDEX|VIEW_MONO_LEFT|VIEW_RIGHT|EYE_OFFSET|VERTEX_ID|BONE_INDICES|BONE_WEIGHTS|Z_CLIP_SCALE|CUSTOM0|CUSTOM1|CUSTOM2|CUSTOM3)\\b"
        }
      ]
    },
    "builtin-variables-fragment": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(VIEWPORT_SIZE|FRAGCOORD|FRONT_FACING|VIEW|UV|UV2|COLOR|POINT_COORD|OUTPUT_IS_SRGB|MODEL_MATRIX|MODEL_NORMAL_MATRIX|VIEW_MATRIX|INV_VIEW_MATRIX|PROJECTION_MATRIX|INV_PROJECTION_MATRIX|NODE_POSITION_WORLD|NODE_POSITION_VIEW|CAMERA_POSITION_WORLD|CAMERA_DIRECTION_WORLD|CAMERA_VISIBLE_LAYERS|VERTEX|LIGHT_VERTEX|VIEW_INDEX|VIEW_MONO_LEFT|VIEW_RIGHT|EYE_OFFSET|SCREEN_UV|DEPTH|NORMAL|TANGENT|BINORMAL|NORMAL_MAP|NORMAL_MAP_DEPTH|BENT_NORMAL_MAP|ALBEDO|ALPHA|METALLIC|SPECULAR|ROUGHNESS|EMISSION|AO|ALPHA_SCISSOR_THRESHOLD|ALPHA_HASH_SCALE|ALPHA_ANTIALIASING_EDGE|ALPHA_TEXTURE_COORDINATE|PREMUL_ALPHA_FACTOR|RIM|RIM_TINT|CLEARCOAT|CLEARCOAT_GLOSS|ANISOTROPY|ANISOTROPY_FLOW|SSS_STRENGTH|SSS_TRANSMITTANCE_COLOR|SSS_TRANSMITTANCE_DEPTH|SSS_TRANSMITTANCE_BOOST|BACKLIGHT|AO_LIGHT_AFFECT|FOG|RADIANCE|IRRADIANCE)\\b"
        }
      ]
    },
    "builtin-variables-canvasitem": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(AT_LIGHT_PASS|CANVAS_MATRIX|INSTANCE_CUSTOM|INSTANCE_ID|NORMAL_TEXTURE|POINT_COORD|REGION_RECT|SCREEN_MATRIX|SCREEN_PIXEL_SIZE|SHADOW_VERTEX|SPECULAR_SHININESS|SPECULAR_SHININESS_TEXTURE|SPHERE_INDEX|TEXTURE|TEXTURE_PIXEL_SIZE|CUSTOM0|CUSTOM1)\\b"
        }
      ]
    },
    "builtin-variables-particles": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(PARTICLE_INDEX|PARTICLE_LIFETIME|PARTICLE_START_LIFETIME|PARTICLE_POSITION|PARTICLE_VELOCITY|PARTICLE_COLOR|PARTICLE_CUSTOM|PARTICLE_FLAG_ALIVE|PARTICLE_FLAG_DEAD|PARTICLE_FLAG_CUSTOM|PARTICLE_GLOBAL_AABB|EMISSION_TRANSFORM|COLOR|VELOCITY|MASS|ACTIVE|RESTART|CUSTOM|TRANSFORM|LIFETIME)\\b"
        }
      ]
    },
    "builtin-variables-light": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(DIFFUSE_LIGHT|LIGHT|LIGHT_COLOR|LIGHT_DIRECTION|LIGHT_ENERGY|LIGHT_IS_DIRECTIONAL|LIGHT_POSITION|LIGHT_VERTEX|SPECULAR_AMOUNT|SPECULAR_LIGHT|ATTENUATION)\\b"
        }
      ]
    },
    "builtin-matrices-vertex": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(MODELVIEW_MATRIX|MODELVIEW_NORMAL_MATRIX|MODEL_MATRIX|MODEL_NORMAL_MATRIX|VIEW_MATRIX|INV_VIEW_MATRIX|PROJECTION_MATRIX|INV_PROJECTION_MATRIX|MAIN_CAM_INV_VIEW_MATRIX)\\b"
        }
      ]
    },
    "builtin-matrices-fragment": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(MODEL_MATRIX|MODEL_NORMAL_MATRIX|VIEW_MATRIX|INV_VIEW_MATRIX|PROJECTION_MATRIX|INV_PROJECTION_MATRIX)\\b"
        }
      ]
    },
    "builtin-matrices-light": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(MODEL_MATRIX|VIEW_MATRIX|PROJECTION_MATRIX|INV_PROJECTION_MATRIX|INV_VIEW_MATRIX)\\b"
        }
      ]
    },
    "builtin-variables-sky": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(TIME|PI|TAU|E|POSITION|RADIANCE|AT_HALF_RES_PASS|AT_QUARTER_RES_PASS|AT_CUBEMAP_PASS|LIGHT0_ENABLED|LIGHT0_ENERGY|LIGHT0_DIRECTION|LIGHT0_COLOR|LIGHT0_SIZE|LIGHT1_ENABLED|LIGHT1_ENERGY|LIGHT1_DIRECTION|LIGHT1_COLOR|LIGHT1_SIZE|LIGHT2_ENABLED|LIGHT2_ENERGY|LIGHT2_DIRECTION|LIGHT2_COLOR|LIGHT2_SIZE|LIGHT3_ENABLED|LIGHT3_ENERGY|LIGHT3_DIRECTION|LIGHT3_COLOR|LIGHT3_SIZE|EYEDIR|SCREEN_UV|SKY_COORDS|HALF_RES_COLOR|QUARTER_RES_COLOR|COLOR|ALPHA|FOG)\\b"
        }
      ]
    },
    "builtin-variables-fog": {
      "patterns": [
        {
          "name": "variable.language.gdshader",
          "match": "\\b(TIME|PI|TAU|E|WORLD_POSITION|OBJECT_POSITION|UVW|SIZE|SDF|ALBEDO|DENSITY|EMISSION)\\b"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.gdshader",
          "match": "\\b(texture|textureLod|textureProj|textureGrad|textureProjLod|textureProjGrad|textureCube|textureCubeLod|textureArray|textureSize|textureQueryLod|textureQueryLevels|textureGather|texelFetch|mix|clamp|smoothstep|step|min|max|abs|sign|floor|ceil|round|roundEven|trunc|fract|mod|modf|fma|pow|sqrt|inversesqrt|exp|exp2|log|log2|sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|asinh|acosh|atanh|length|distance|dot|cross|normalize|reflect|refract|faceforward|determinant|transpose|inverse|outerProduct|matrixCompMult|dFdx|dFdxCoarse|dFdxFine|dFdy|dFdyCoarse|dFdyFine|fwidth|fwidthCoarse|fwidthFine|radians|degrees|floatBitsToInt|floatBitsToUint|intBitsToFloat|uintBitsToFloat|isnan|isinf|lessThan|greaterThan|lessThanEqual|greaterThanEqual|equal|notEqual|any|all|not|bitfieldExtract|bitfieldInsert|bitfieldReverse|bitCount|findLSB|findMSB|imulExtended|umulExtended|uaddCarry|usubBorrow|packHalf2x16|unpackHalf2x16|packUnorm2x16|unpackUnorm2x16|packSnorm2x16|unpackSnorm2x16|packUnorm4x8|unpackUnorm4x8|packSnorm4x8|unpackSnorm4x8|ldexp|frexp|bool|int|uint|float|vec2|vec3|vec4|mat2|mat3|mat4)\\b"
        }
      ]
    },
    "render-mode-values": {
      "patterns": [
        {
          "name": "storage.modifier.rendermode.gdshader",
          "match": "\\b(alpha_to_coverage|alpha_to_coverage_and_one|ambient_light_disabled|ambient_light_enabled|blend_add|blend_mix|blend_mul|blend_premul_alpha|blend_sub|cull_back|cull_disabled|cull_front|debug_shadow_splits|depth_draw_alpha_prepass|depth_draw_always|depth_draw_never|depth_draw_opaque|depth_prepass_alpha|depth_test_default|depth_test_disabled|depth_test_inverted|diffuse_burley|diffuse_lambert|diffuse_lambert_wrap|diffuse_toon|disable_fog|do_not_delay_visibility|ensure_correct_normals|fog_disabled|light_disabled|light_enabled|particle_collisions_disabled|particle_collisions_enabled|particle_trails|shadow_to_opacity|shadows_disabled|shadows_enabled|skip_vertex_transform|specular_disabled|specular_schlick_ggx|specular_toon|sss_mode_skin|unshaded|use_half_res_pass|use_quarter_res_pass|vertex_lighting|wireframe|world_vertex_coords)\\b"
        }
      ]
    },
    "stencil-mode-values": {
      "patterns": [
        {
          "name": "storage.modifier.stencilmode.gdshader",
          "match": "\\b(compare_always|compare_equal|compare_greater|compare_greater_or_equal|compare_less|compare_less_or_equal|compare_not_equal|read|write|write_if_depth_fail)\\b"
        }
      ]
    },
    "shader-type-values": {
      "patterns": [
        {
          "name": "entity.name.type.gdshader",
          "match": "\\b(canvas_item|fog|particles|sky|spatial)\\b"
        }
      ]
    },
    "hint-attributes": {
      "patterns": [
        {
          "name": "storage.modifier.hint.gdshader",
          "match": "\\b(source_color|hint_default_white|hint_default_black|hint_default_transparent|hint_normal|hint_depth_texture|hint_screen_texture|hint_anisotropy|hint_normal_roughness_texture|hint_roughness_r|hint_roughness_g|hint_roughness_b|hint_roughness_a|hint_roughness_normal|hint_roughness_gray|hint_range|hint_enum|hint_multiline_text|hint_file|hint_dir|filter_nearest|filter_linear|filter_nearest_mipmap|filter_linear_mipmap|repeat_enable|repeat_disable|instance_index)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.gdshader",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.gdshader",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.hex.gdshader",
          "match": "\\b0[xX][0-9a-fA-F]+(\\.[0-9a-fA-F]+)?[pP][+-]?\\d+[fF]?(?!\\w)"
        },
        {
          "name": "constant.numeric.gdshader",
          "match": "\\b(0[xX][0-9a-fA-F]+[uU]?|0[bB][01]+[uU]?)(?!\\w)"
        },
        {
          "name": "constant.numeric.float.gdshader",
          "match": "\\b(\\d+\\.\\d*[eE][+-]?\\d+[fF]?|\\d+[eE][+-]?\\d+[fF]?|\\d+\\.\\d*[fF]|\\d+\\.\\d+[fF]?|\\d+\\.|\\d+[fF])(?!\\w)"
        },
        {
          "name": "constant.numeric.float.gdshader",
          "match": "\\.\\d+[eE][+-]?\\d+[fF]?(?!\\w)"
        },
        {
          "name": "constant.numeric.float.gdshader",
          "match": "\\.\\d+[fF]?(?!\\w)"
        },
        {
          "name": "constant.numeric.integer.gdshader",
          "match": "\\b\\d+[uU]?(?!\\w)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.gdshader",
          "match": "\\b(vertex|fragment|light|sky|fog)\\b(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.gdshader"
            }
          }
        },
        {
          "name": "meta.function.call.gdshader",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b\\s*\\(",
          "captures": {
            "1": {
              "name": "support.function.gdshader"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.gdshader",
          "match": "[*+/%=<>!&|^~?:-]"
        }
      ]
    },
    "swizzle": {
      "patterns": [
        {
          "name": "variable.other.swizzle.gdshader",
          "match": "(\\.)([xyzwrgbaXYZWRGBAstpqSTPQ]{1,4})\\b",
          "captures": {
            "1": {
              "name": "punctuation.separator.dot.gdshader"
            },
            "2": {
              "name": "variable.other.swizzle.gdshader"
            }
          }
        }
      ]
    },
    "punctuation-comma": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.gdshader",
          "match": ","
        }
      ]
    },
    "punctuation-semicolon": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.gdshader",
          "match": ";"
        }
      ]
    },
    "punctuation-dot": {
      "patterns": [
        {
          "name": "punctuation.separator.dot.gdshader",
          "match": "\\."
        }
      ]
    }
  },
  "scopeName": "source.gdshader"
}